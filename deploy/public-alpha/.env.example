# deploy/public-alpha/.env.example — copy to .env (chmod 0600), fill in, NEVER commit.
#
# TWICESHY_TOKEN is the OPERATOR bearer: full pull access (search/get/record,
# report_outcome/report_issue) plus GET /statz. It is NOT a self-serve tok_
# token — those are minted per-visitor via POST /signup.
# Generate with: openssl rand -hex 32
TWICESHY_TOKEN=

# ntfy alert channel for serve-fatal / SIGHUP-reload-failed alarms. Unset =
# no-op (fail-open) — the server and corpus-refresh.sh both tolerate it being
# empty. Must be topic-qualified (https://host/<topic>): a bare host 400s and
# the alert silently drops even with a valid token (#0093).
TWICESHY_ALERT_URL=
NTFY_TOKEN=

# Reverse proxies allowed to set X-Forwarded-For for the signup per-IP cap
# (#0131). For the shipped compose stack this is the compose network's subnet
# (docker network inspect public-alpha_default); unset = trust RemoteAddr only.
TWICESHY_TRUSTED_PROXIES=

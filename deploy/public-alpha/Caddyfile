# deploy/public-alpha/Caddyfile — public-alpha TLS + static landing + reverse
# proxy (#0129, ADR-0030). Must stay consistent with compose.yaml (service name
# `twiceshy`, port 8722) and docs/DEPLOY-public-alpha.md.
#
# OPEN DECISION (domain — see the runbook): twiceshy.app / api.twiceshy.app are
# PLACEHOLDERS. Substitute the real domain(s) before deploy; Caddy issues
# Let's Encrypt certs automatically for whatever hostnames are configured here.
#
# Two site blocks:
#   - twiceshy.app / www — the marketing + self-serve domain: serves
#     web/landing/ as a static root (/, /docs, /terms map to the *.html files),
#     and reverse-proxies POST /signup + GET /statz to twiceshy:8722 so the
#     landing page's own signup form (fetch("/signup")) stays same-origin.
#     GET /demo-search is proxied the same way for the live try-a-search box (#0132).
#   - api.twiceshy.app — the MCP domain: everything here is non-static, so the
#     whole vhost reverse-proxies to twiceshy:8722 (this is what MCP clients
#     configure; /healthz, /readyz, /signup, /statz are reachable here too).
#
# X-Forwarded-For: reverse_proxy sets this by default. The server honors it
# only when TWICESHY_TRUSTED_PROXIES covers this container's network (#0131),
# which makes the signup per-IP cap per-visitor — set that env on the twiceshy
# service or the cap degrades to keying on Caddy's own IP.
{
	# Let's Encrypt account contact (certificate expiry notices). Cloudflare
	# Email Routing forwards this to the owner; the repo is public now so this
	# is safe to publish.
	email contact@twiceshy.app
}

twiceshy.app, www.twiceshy.app {
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}

	# Access logs: default JSON to stdout — docker's json-file log driver
	# already bounds rotation, so no extra config needed here.
	log

	root * /srv/landing

	# Legacy/direct .html hits: permanent-redirect to the clean routes; anything
	# not redirected or matched below falls through to the API proxy and 401s.
	redir /index.html / permanent
	redir /docs.html /docs permanent
	redir /terms.html /terms permanent

	# static assets (SEO files + brand icons) under web/landing/ — without
	# this handle they'd fall through to the catch-all `handle` below and
	# reverse-proxy to twiceshy instead of being served, so they'd never be
	# reachable.
	@seo path /robots.txt /llms.txt /sitemap.xml /favicon.svg /favicon.ico /favicon-32.png /apple-touch-icon.png /og-image.png /logo-512.png /32c21b52f05b41fa6a8f76fed9626187.txt
	handle @seo {
		file_server
	}

	handle /docs {
		rewrite * /docs.html
		file_server
	}

	handle /terms {
		rewrite * /terms.html
		file_server
	}

	handle /signup {
		reverse_proxy twiceshy:8722
	}

	handle /demo-search {
		reverse_proxy twiceshy:8722
	}

	handle /statz {
		reverse_proxy twiceshy:8722
	}

	handle / {
		file_server
	}

	# Catch-all: anything else non-static (/push, /retro, MCP, …) to twiceshy.
	handle {
		reverse_proxy twiceshy:8722
	}
}

api.twiceshy.app {
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}

	# Access logs: default JSON to stdout — docker's json-file log driver
	# already bounds rotation, so no extra config needed here.
	log

	# Everything is non-static on this vhost — the MCP endpoint (mounted at "/"
	# in the server) plus /healthz, /readyz, /signup, /statz.
	reverse_proxy twiceshy:8722
}
